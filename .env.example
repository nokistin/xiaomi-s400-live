# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit it.

# Mi Cloud account that owns the scale (used by MiCloudClient)
MI_EMAIL=your-email@example.com
MI_PASSWORD=your-password

# BLE MAC of your scale (uppercase, colons). Look up in Mi Home app
# or via examples/cloud_probe.py.
SCALE_MAC=CC:4D:75:XX:XX:XX

# User profile for body composition (optional)
USER_SEX=male            # "male" or "female"
USER_AGE_YEARS=30
USER_HEIGHT_CM=175

# Optional — only needed by examples/local_test.py (skips Mi Cloud entirely)
# Extract via https://github.com/PiotrMachowski/Xiaomi-cloud-tokens-extractor
# BINDKEY_HEX=
# TOKEN_HEX=
